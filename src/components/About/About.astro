---
/**
 * * About section
 */

import profileImage from "@assets/images/proj.webp";
import { Image } from "astro:assets";
interface teamItem {
	name: string; 
	title: string;
	image: ImageMetadata; // imported image
}

import image3 from "@assets/images/Neorama.png";
import image1 from "@assets/images/Neorama.png";
import image2 from "@assets/images/Neorama.png";


const aboutData: teamItem[] = [
	{
		name: "Liron Orlev",
		title:"Community Manager",
		image: image1,
	},
	{
		name: "Orri J. Avraham",
		title: "Development Manager",

		image: image2,
	},
	{
		name: "Alkinoos Konis (NEXUS)",
		title: "Legal Counsel",

		image: image3,
	},
		{
		name: "Irene Ioannidou",
		title:"Architect",
		image: image1,
	},
	{
		name: "Tassos Gkanilas",
		title: "Land Surveyor",

		image: image2,
	},
	{
		name: "Anastasia Ladopoulou",
		title: "Legal Counsel",

		image: image3,
	},
];
---

<section id="about" class="site-container scroll-mt-10 py-8 md:py-12">
	<div class="flex flex-col md:flex-row items-center justify-center">
		<div class="md:w-2/3">
			<h2 class="h3 text-primary-500 text-pretty uppercase">Meet the team</h2>
			<h3 class="h2 mt-4">Neorama</h3>
			<div class="bg-base-100 mt-8 p-8 md:mb-20 lg:text-lg">
				<p>
					Every ambitious project requires the right combination of professionals to bring the vision to life. Neorama is being built by an A-team of architects, land surveyors, lawyers, community planners and managers to create the world-class experience of luxury countryside life. 


				</p>
				<div class="flex w-3/4 justify-end">
					<p class="font-heading-1 text-3xl italic"></p>
				</div>
			</div>
		</div>
		<div class="mr-auto max-w-md md:w-1/3 md:max-w-none ">
			<div class="my-auto aspect-[3/4] w-full overflow-hidden">
				<Image
					src={profileImage}
					alt="Neorama"
					width={450}
					class="h-auto w-auto min-w-full object-cover  md:mt-40 "
				/>
			</div>
		</div>
	</div>
		<div class="grid gap-4  sm:grid-cols-[repeat(auto-fit,minmax(20rem,2fr))]">
{
aboutData.map((about) =>(
			<div class="site-container bg-base-100">
					<Image
					src={about.image}
					alt="Neorama"

					class="h-auto w-full  "
				/>
				  <h3 class="h3 text-center">
{about.name}
            </h3>
			            <ul class="mt-4 space-y-3">
{about.title}

				</ul>
				</div>
			))	
		}

</div>

				
</div>
</section>
