---
/**
 * * Pricing cards with three cards
 */

import Button from "@components/Button/Button.astro";
import { Image } from "astro:assets";
import Carousel from "@components/Carousel/Carousel.astro";

interface pricingItem {
	name: string; // plan name
	featured?: boolean; // if true, will be highlighted or otherwise featured
	price: string;
	features: string[]; // list of features
	image: ImageMetadata; // imported image
}

import image3 from "@assets/images/olympus.png";
import image1 from "@assets/images/home view 3.webp";
import image2 from "@assets/images/agean.png";

// This is designed for 3 pricing items, but can be modified to support more
const pricingData: pricingItem[] = [
	{
		name: "Alpha",
		featured: true,
		price: "285,000",
		features: [
			 "2,000 sqm plot of land with a 110 sqm home.",
"Custom interior design: 3 bedrooms, 2 bathrooms, kitchen, living room, veranda, storage."

		],
		image: image1,
	},
	{
		name: "Agean",
		featured: true,
		price: "455,000",
		features: [
						 			 "2,000 sqm plot of land with a 140 sqm home.",
"Custom interior design: 3-4 bedrooms, 2 bathrooms, kitchen, living room, veranda, storage."


		],
		image: image2,
	},
	{
		name: "Olympus",
		featured: true,
		price: "535,000",
		features: [
			 			 "4,000 sqm plot of land with a 180 sqm home",
						 "Custom interior design: 4-5 bedrooms, 2-3 bathrooms, kitchen, living room, veranda, balcony, storage."


		],
		image: image3,
	},
];
---

<section id="pricing" class="mx-auto max-w-6xl scroll-mt-10 px-4 py-2 md:py-12">


	<!-- works for 3 pricing plans, adjust grid cols here to support more or less -->
<Carousel>
{
  pricingData.map((plan) => (

    <div class="px-4 flex h-full">

      <div class="flex w-full flex-col overflow-hidden  bg-base-100 shadow-lg">

        <!-- image -->
        <div class="h-64 w-full overflow-hidden">
          <Image
            src={plan.image}
            alt={plan.name}
            width={600}
            class="h-full w-full object-cover"
          />
        </div>

        <!-- content -->
        <div class="flex flex-1 flex-col justify-between p-8">

          <div>

            <h3 class="h2 text-center">
              {plan.name}
            </h3>

            <ul class="mt-4 space-y-3">
              {plan.features.map((feature) => (
                <li class="text-base leading-snug">
                  {feature}
                </li>
              ))}
            </ul>

          </div>

          <p class="mt-8 text-center text-[2rem] font-medium">
            €{plan.price}
          </p>

        </div>

      </div>

    </div>

  ))
}
</Carousel>

	<div class="mt-12 flex justify-center">
		<Button href="/specifications" variant="outline" class="px-8">Learn More</Button>
	</div>
</section>
